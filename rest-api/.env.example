# ============================================================
# FileMaker DuckDB Analysis API - Environment Configuration
# ============================================================
# Relative Pfade (DUCKDB_PATH, LOG_FILE, XML_*) beziehen sich
# auf das rest-api/ Verzeichnis. Template-Pfade werden automatisch
# als absolute Pfade aufgelöst und müssen hier nicht gesetzt werden.
# ============================================================

# Server Configuration
PORT=3003
HOST=localhost
NODE_ENV=development

# Database Configuration (lokale READ_ONLY-Kopie der Master-DB)
# Die Kopie wird von convert-xml nach jedem erfolgreichen Import aktualisiert
# (siehe project/plan-db-architektur.md).
DUCKDB_PATH=./db/fm_catalog.duckdb
DUCKDB_MAX_MEMORY=2GB
DUCKDB_THREADS=4

# Admin-Endpoint Schutz (optional). Wenn gesetzt, muss der Reload-Endpoint
# einen passenden X-Admin-Token Header mitschicken. Leer = offener Dev-Zugriff.
ADMIN_RELOAD_TOKEN=

# Template Configuration
# TEMPLATE_DIR and TEMPLATE_CUSTOM_DIR werden automatisch als absolute Pfade
# relativ zur environment.js aufgelöst. Nur setzen wenn ein abweichender
# absoluter Pfad benötigt wird, z.B.:
# TEMPLATE_DIR=/absolute/path/to/templates/sql
TEMPLATE_CACHE_ENABLED=true
TEMPLATE_CACHE_TTL=3600000

# XML Import Configuration (Parent project)
XML_DIR=../xml
CONVERT_XML_SCRIPT=../sql/convert_xml.sql
CREATE_CATALOGS_SCRIPT=../sql/create_universal_catalogs.sql

# Obsidian Documentation (External - absolute path)
# OBSIDIAN_VAULT_PATH=/absolute/path/to/obsidian/vault

# API Configuration
DEFAULT_LIMIT=100
MAX_LIMIT=10000
REQUEST_TIMEOUT_MS=30000

# Logging (Local to API)
LOG_LEVEL=info
LOG_FILE=./logs/api.log

# CORS
CORS_ENABLED=true
CORS_ORIGIN=*

# Plugin-Funktions-Dokumentation (MBS, etc.)
# Pfad zum docs/mbs Verzeichnis (relativ zur rest-api/).
PLUGIN_DOCS_MBS_PATH=../docs/mbs
PLUGIN_DOCS_CACHE_TTL_MS=3600000
PLUGIN_DOCS_CACHE_MAX_DOCS=500
PLUGIN_DOCS_CACHE_MAX_PATHS=1000

# Reference-DB (lösungsunabhängige FileMaker-Referenz, Script Steps + Functions
# + Claris-Hilfe-Mirror). Wird per ATTACH AS ref READ_ONLY angehängt.
REFERENCE_DUCKDB_PATH=./db/fm_reference.duckdb
REFERENCE_HTML_ROOT=../docs/claris-help
REFERENCE_CACHE_TTL_MS=3600000
REFERENCE_HTML_CACHE_TTL_MS=86400000
REFERENCE_DEFAULT_LANG=de
