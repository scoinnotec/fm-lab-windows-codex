# macOS-specific files
.DS_Store

# Environment variable files
.env
.env.local

# IDE-specific files
.vscode/
.idea/

# Log files
*.log
logs/*
!logs/.gitkeep

# Database files
*.duckdb
*.duckdb.wal
db/*
!db/.gitkeep
# Reference DB is shipped with the repo (FileMaker function and script step reference)
!rest-api/db/fm_reference.duckdb

# Data directory
data/*
!data/.gitkeep

# XML files
xml/*
!xml/.gitkeep

# Docs directory (loaded on demand via install skills)
docs/*
!docs/.gitkeep
!docs/agents/
!docs/agents/**
!docs/fm-lab/
!docs/fm-lab/**

# Node.js dependencies
node_modules/
package-lock.json

# Workspaces - build artifacts
rest-api/logs
rest-api/.env
packages/shared/dist/
packages/shared/generated/*.js
packages/shared/generated/*.d.ts
packages/shared/generated/*.map
apps/*/node_modules
apps/*/dist
apps/*/build
apps/*/.env.local
apps/*/.env.production

# Local Claude settings
.claude/settings.json
.claude/settings.local.json
.claude/worktrees/

# Plugin settings (local, generated on first run)
.fmlab/plugins.json
.fmlab/plugins/
