# macOS-specific files
.DS_Store

# Environment variable files
.env
.env.local

# IDE-specific files
.vscode/
.idea/

# Log files
*.log
logs/*
!logs/.gitkeep

# Database files
*.duckdb
*.duckdb.wal
db/*
!db/.gitkeep
# DuckDB files are local runtime artifacts. The optional FileMaker reference DB
# can be placed in rest-api/db/fm_reference.duckdb, but is not committed.

# Data directory
data/*
!data/.gitkeep
!data/mbs_component_exceptions.csv
rest-api/data/*
!rest-api/data/.gitkeep

# XML files
xml/*
!xml/.gitkeep
!xml/Kontakte.xml

# Local FileMaker files
fm/*
!fm/.gitkeep

# Docs directory (loaded on demand via install skills)
docs/*
!docs/.gitkeep
!docs/windows-codex.md
!docs/ASCII-Logo.txt
!docs/agents/
!docs/agents/**

# Node.js dependencies
node_modules/
package-lock.json

# Workspaces - build artifacts
rest-api/logs
rest-api/.env
packages/shared/dist/
packages/shared/generated/*.js
packages/shared/generated/*.d.ts
packages/shared/generated/*.map
apps/*/node_modules
apps/*/dist
apps/*/build
apps/*/.env.local
apps/*/.env.production

# Local Claude settings
.claude/settings.json
.claude/settings.local.json
.claude/worktrees/

# Plugin settings (local, generated on first run)
.fmlab/plugins.json
.fmlab/plugins/
.fmlab/local-settings.json
