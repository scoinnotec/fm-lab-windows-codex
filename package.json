{
  "name": "fm-lab",
  "version": "0.6.0",
  "description": "FileMaker XML Analysis with DuckDB - Multi-Frontend Architecture",
  "private": true,
  "workspaces": [
    "rest-api",
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace=rest-api",
    "dev:shared": "npm run build:watch --workspace=packages/shared",
    "build:shared": "npm run build --workspace=packages/shared",
    "generate:types": "npm run generate --workspace=packages/shared",
    "install:all": "npm install && npm install --workspaces",
    "clean": "npm run clean --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  },
  "keywords": [
    "filemaker",
    "duckdb",
    "xml",
    "analysis",
    "monorepo"
  ],
  "author": "Marcel Moré",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
